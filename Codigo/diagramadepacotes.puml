@startuml
title Diagrama de Pacotes

scale 0.8
left to right direction

skinparam dpi 120
skinparam packageStyle rectangle
skinparam backgroundColor #FAFAFA

skinparam package {
  BackgroundColor #F0F3F5
  BorderColor #2D3436
  FontColor #2D3436
  FontSize 11
  FontStyle bold
}

' =========================
' CAMADA DE APRESENTAÇÃO
' =========================

package "Apresentação" #FFEAA7 {

  package "Controller" #FFF3E0 {
    [CompeticaoController]
    [ResultadoController]
    [AuthController]
    [RelatorioController]
    [InscricaoController]
    [LocalController]
  }

  package "DTO" #FFF3E0 {
    [AtletaDTO]
    [CompeticaoDTO]
    [ResultadoDTO]
    [InscricaoDTO]
    [RelatorioDTO]
  }

  package "Validator" #FFF3E0 {
    [InscricaoValidator]
    [CompeticaoValidator]
    [ResultadoValidator]
    [LocalValidator]
  }
}

' =========================
' CAMADA DE NEGÓCIO
' =========================

package "Negócio" #D5E8D4 {

  package "Facade" {
    [SGOFacade]
    [CompeticaoFacade]
  }

  package "Service" {
    [AtletaService]
    [CompeticaoService]
    [ResultadoService]
    [LocalService]
    [AutenticacaoService]
    [RelatorioService]
    [InscricaoService]
    [PaisService]
    [MedalhaService]
  }

  package "Security" #F8C471 {
    [JwtTokenProvider]
    [PasswordEncoder]
    [AutenticacaoManager]
    [AutorizacaoManager]
  }

  package "Rules" {
    [ValidacaoHorario]
    [ValidacaoPais]
    [ValidacaoPodio]
  }
}

' =========================
' CAMADA DE DADOS
' =========================

package "Dados" #AED6F1 {

  package "Repository" {
    [CompeticaoRepository]
    [AtletaRepository]
    [ResultadoRepository]
    [UsuarioRepository]
    [RelatorioRepository]
    [InscricaoRepository]
    [LocalRepository]
    [PaisRepository]
  }

  package "DAO" {
    [CompeticaoDAO]
    [ResultadoDAO]
    [UsuarioDAO]
    [RelatorioDAO]
    [InscricaoDAO]
    [PaisDAO]
  }

  package "Model" {
    [Competicao]
    [Atleta]
    [Operador]
    [Usuario]
    [Pais]
    [Resultado]
    [Inscricao]
    [Relatorio]
    [Local]
    [Medalha]
  }

  package "Mapper" {
    [CompeticaoMapper]
    [AtletaMapper]
    [ResultadoMapper]
  }
}

' =========================
' INFRAESTRUTURA
' =========================

package "Infraestrutura" #E5E8E8 {

  package "Config" {
    [CorsConfig]
    [SecurityConfig]
    [DatabaseConfig]
  }

  package "Exception" #FADBD8 {
    [ValidationException]
    [BusinessException]
    [NotFoundException]
  }

  package "Util" {
    [DateUtils]
    [ValidatorUtil]
    [MedalhaCalculator]
  }
}

database "SGO_DB" as DB

' =========================
' RELACIONAMENTOS
' =========================

Controller --> Facade
Controller --> DTO
Controller --> Validator

Facade --> Service

Service --> Security
Service --> Repository
Service --> DAO
Service --> Rules

DAO --> DB
Repository --> DB

Config --> Security
Config --> DB

Mapper --> Model

@enduml
